{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "..",
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "outDir": "out-tsc",
    "tsBuildInfoFile": ".tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "prisma.config.ts",
    "prisma/**/*.ts",
    "../shared/src/**/*.ts",
    "../prismagen/src/**/*.ts"
  ]
}
