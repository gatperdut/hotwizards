generator client {
  provider            = "prisma-client"
  output              = "../../prismagen/src"
  moduleFormat        = "esm"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  handle    String   @unique
  email     String   @unique
  password  String
  admin     Boolean  @default(false)
  createdAt DateTime @default(now())
}
