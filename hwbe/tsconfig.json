{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2023",
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "rootDir": "..",
    "outDir": "./dist",
    "composite": false,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
  },
  "include": [
    "../shared/src/**/*"
  ]
}
