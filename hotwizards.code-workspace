{
  "folders": [
    {
      "name": "ROOT",
      "path": "./",
    },
    {
      "name": "HWBE",
      "path": "hwbe",
    },
    {
      "name": "HWFE",
      "path": "hwfe",
    },
    {
      "name": "SHARED",
      "path": "shared",
    },
  ],
  "settings": {
    "files.exclude": {
      "hwbe": true,
      "hwfe": true,
      "shared": true
    },
    "search.exclude": {
      "**/package-lock.json": true,
      "**/node_modules": true,
      "**/dist": true,
    },
  },
  "extensions": {
    "recommendations": [
      "dbaeumer.vscode-eslint",
      "esbenp.prettier-vscode",
      "angular.ng-template",
      "firsttris.vscode-jest-runner",
      "mrmlnc.vscode-scss",
    ],
  },
}
