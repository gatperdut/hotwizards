{
  "name": "hotwizards",
  "description": "Hot Wizards Monorepo",
  "type": "module",
  "author": "carlosrb",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": ["hwbe", "hwfe", "shared", "prismagen"],
  "scripts": {
    "hwbe:start": "npm run start -w @hw/hwbe",
    "hwbe:build": "npm run build -w @hw/hwbe",
    "hwbe:clean": "npm run clean -w @hw/hwbe",
    "hwbe:prisma:gen": "npm run prisma:gen -w @hw/hwbe",
    "hwbe:prisma:migrate:dev": "npm run prisma:migrate:dev -w @hw/hwbe",
    "hwbe:prisma:migrate:deploy": "npm run prisma:migrate:deploy -w @hw/hwbe",
    "hwfe:start": "npm run start -w @hw/hwfe",
    "hwfe:build": "npm run build -w @hw/hwfe",
    "hwfe:clean": "npm run clean -w @hw/hwfe",
    "prismagen:clean": "npm run clean -w @hw/prismagen",
    "clean": "rm -rf node_modules package-lock.json",
    "clean:all": "npm run hwbe:clean && npm run hwfe:clean && npm run prismagen:clean && npm run clean"
  },
  "dependencies": {
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "^3.8.1",
    "tslib": "^2.3.0",
    "typescript-eslint": "8.58.0",
    "typescript": "^5.9.2"
  }
}
