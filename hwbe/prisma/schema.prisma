generator client {
  provider = "prisma-client"
  output   = "../../generated"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  handle    String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}