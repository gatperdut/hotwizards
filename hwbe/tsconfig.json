{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "composite": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "removeComments": true,
    "incremental": true,
    "emitDecoratorMetadata": true,
    "outDir": "dist"
  },
  "include": [
    "src/**/*.ts",
    "prisma.config.ts",
    "prisma/**/*.ts",
    "../shared/src/users/user-availability-handle.dto.ts",
    "../shared/src/users/user-availability-email.dto.ts",
    "../shared/src/users/user-availability-response.dto.ts",
    "../shared/src/users/user-by-email.dto.ts",
    "../shared/src/users/user-by-id.dto.ts",
    "../shared/src/users/user-create.dto.ts",
    "../shared/src/users/player.dto.ts"
  ]
  // "references": [{ "path": "../shared/tsconfig.json" }, { "path": "../prismagen/tsconfig.json" }]
}
