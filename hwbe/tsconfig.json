{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "module": "esnext",
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "composite": true,
    "removeComments": true,
    "incremental": true,
    "emitDecoratorMetadata": true,
    "outDir": "out-tsc"
  },
  "include": [
    "src/**/*.ts",
    "prisma.config.ts",
    "prisma/**/*.ts",
    "../shared/src/**/*.ts",
    "../prismagen/src/**/*.ts"
  ]
}
