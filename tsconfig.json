{
  "compilerOptions": {
    "strict": true,
    "strictPropertyInitialization": false,
    "target": "es2024",
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "paths": {
      "@hw/shared": ["./shared/src/*"],
      "@hw/hwbe/*": ["./hwbe/src/*"],
      "@hw/hwfe/*": ["./hwfe/src/*"],
      "hw/prismagen/*": ["./prismagen/src/*"]
    }
  },
  "references": [
    { "path": "./hwbe/tsconfig.json" },
    { "path": "./hwfe/tsconfig.json" },
    { "path": "./shared/tsconfig.json" },
    { "path": "./prismagen/tsconfig.json" }
  ]
}
