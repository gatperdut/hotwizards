generator client {
  provider            = "prisma-client"
  output              = "../../prismagen/src"
  moduleFormat        = "esm"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  handle    String   @unique
  email     String   @unique
  password  String
  admin     Boolean  @default(false)
  createdAt DateTime @default(now())

  masterships Campaign[]   @relation("CampaignMaster")
  memberships Membership[]
}

model Campaign {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  masterId Int
  master   User @relation("CampaignMaster", fields: [masterId], references: [id], onDelete: Cascade)

  memberships Membership[]

  ruleset Ruleset?
}

enum Movement {
  REGULAR
  BALANCED
}

enum MembershipStatus {
  PENDING
  ACTIVE
}

enum Gender {
  MALE
  FEMALE
}

enum Klass {
  BARBARIAN
  WIZARD
  ELF
  DWARF
}

model Ruleset {
  id       Int      @id @default(autoincrement())
  aoo      Boolean  @default(true)
  movement Movement @default(REGULAR)

  campaignId Int      @unique
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Membership {
  id       Int      @id @default(autoincrement())
  joinedAt DateTime @default(now())

  status MembershipStatus @default(PENDING)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  campaignId Int
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character  Character?

  @@unique([userId, campaignId])
}

model Character {
  id     Int    @id @default(autoincrement())
  name   String
  klass  Klass
  gender Gender

  membershipId Int        @unique
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
}
