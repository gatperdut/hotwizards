{
  "compilerOptions": {
    "strict": true,
    "target": "es2024",
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "paths": {
      "@hw/shared": ["./shared/src/index.ts"],
      "@hw/hwbe/*": ["./hwbe/src/*"],
      "@hw/hwfe/*": ["./hwfe/src/*"],
      "@hw/prismagen/client": ["./prismagen/src/client.ts"],
      "@hw/prismagen/browser": ["./prismagen/src/browser.ts"]
    }
  },
  "references": [
    { "path": "./hwbe/tsconfig.json" },
    { "path": "./hwfe/tsconfig.json" },
    { "path": "./shared/tsconfig.json" },
    { "path": "./prismagen/tsconfig.json" }
  ]
}
