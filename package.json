{
  "name": "hotwizards",
  "description": "Hot Wizards Monorepo",
  "type": "module",
  "author": "carlosrb",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": ["hwbe", "hwfe", "shared", "prismagen"],
  "scripts": {
    "start:hwbe": "npm run start -w @hw/hwbe",
    "start:hwfe": "npm run start -w @hw/hwfe",
    "clean:hwbe": "npm run clean -w @hw/hwbe",
    "clean:hwfe": "npm run clean -w @hw/hwfe",
    "clean:all": "npm run clean:hwbe && npm run clean:hwfe && rm -rf node_modules package-lock.json"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "tslib": "^2.3.0",
    "typescript-eslint": "8.58.0",
    "typescript": "^5.9.2"
  }
}
